void Blink(int time){
    LaunchPad_Output(LED_CYAN);
    //LaunchPad_LED(1);
    Clock_Delay1ms(time);
    // LaunchPad_LED(0);
    LaunchPad_Output(LED_OFF);
    Clock_Delay1ms(time);
}

